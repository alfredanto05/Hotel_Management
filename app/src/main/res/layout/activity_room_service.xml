<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#050505"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Room Services"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:textColor="#D4AF37"
        android:shadowColor="#4DD4AF37"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="15" />

    <EditText
        android:id="@+id/etServiceRoomNo"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Enter Guest Room Number"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D4AF37"
        android:inputType="number"
        android:gravity="center"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnRequestCleaning"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Request Room Cleaning"
        android:textColor="#050505"
        android:textStyle="bold"
        android:backgroundTint="#D4AF37"
        android:drawableEnd="@android:drawable/ic_menu_delete"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="In-Suite Dining (Tap to Order):"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="12dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/menuContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/itemPaneer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/ripple_gold"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paneer Tikka Masala" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rich tomato gravy, smoky cottage cheese" android:textSize="14sp" android:textColor="#888888"/>
                        </LinearLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹450" android:textSize="22sp" android:textStyle="bold" android:textColor="#D4AF37"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/itemBiryani"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/ripple_gold"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Awadhi Mutton Biryani" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Slow-cooked basmati, fragrant spices" android:textSize="14sp" android:textColor="#888888"/>
                        </LinearLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹650" android:textSize="22sp" android:textStyle="bold" android:textColor="#D4AF37"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/itemChai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/ripple_gold"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Masala Chai Pot" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Serves 2, includes hot samosas" android:textSize="14sp" android:textColor="#888888"/>
                        </LinearLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹150" android:textSize="22sp" android:textStyle="bold" android:textColor="#D4AF37"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/itemDessert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/ripple_gold"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kesari Rasmalai" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Saffron-infused milk dumplings" android:textSize="14sp" android:textColor="#888888"/>
                        </LinearLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" text="₹200" android:textSize="22sp" android:textStyle="bold" android:textColor="#D4AF37"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>