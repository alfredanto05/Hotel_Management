<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#050505">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete Booking"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:textColor="#D4AF37"
        android:shadowColor="#4DD4AF37"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="15" />

    <LinearLayout
        android:id="@+id/summaryCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_premium_card"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tvSummaryRoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#D4AF37"
            android:text="Room: --" />

        <TextView
            android:id="@+id/tvSummaryDates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#CCCCCC"
            android:text="Dates: -- to --" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guest Information"
        android:textStyle="bold"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etGuestName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Full Name"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D4AF37"
        android:inputType="textPersonName"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etGuestPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Phone Number"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D4AF37"
        android:inputType="phone"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Confirm &amp; Book"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#050505"
        android:backgroundTint="#D4AF37"
        android:drawableEnd="@android:drawable/checkbox_on_background" />

</LinearLayout>