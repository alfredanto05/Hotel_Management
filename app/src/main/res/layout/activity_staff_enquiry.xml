<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#050505"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Staff Directory"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#D4AF37"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Internal Employee Verification"
        android:textSize="14sp"
        android:gravity="center"
        android:textColor="#888888"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/etStaffId"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Enter Staff ID (e.g. EMP-01)"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D4AF37"
        android:inputType="textCapCharacters"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnSearchStaff"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Search Profile"
        android:textColor="#050505"
        android:textStyle="bold"
        android:backgroundTint="#D4AF37"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profile Details:"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#111111"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStaffResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Awaiting query..."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp" />

    </ScrollView>
</LinearLayout>